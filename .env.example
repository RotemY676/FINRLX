# Root-level env example for docker-compose
# Copy to .env and adjust as needed

# Postgres
POSTGRES_USER=finrlx
POSTGRES_PASSWORD=finrlx
POSTGRES_DB=finrlx

# Backend
DATABASE_URL=postgresql+asyncpg://finrlx:finrlx@localhost:5432/finrlx
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=false

# LLM provider — pick ONE mode:
#   (a) Single provider:
#       LLM_PROVIDER=anthropic
#       LLM_ANTHROPIC_API_KEY=sk-ant-...
#   (b) Cascading chain (free-first fallback). Free Gemini is tried
#       first; if it fails or the daily quota is exhausted, the paid
#       Anthropic provider takes over. Get a free Gemini key at
#       https://aistudio.google.com/apikey.
#       LLM_PROVIDER_CHAIN=gemini,anthropic
#       LLM_GEMINI_API_KEY=AIza...
#       LLM_ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL is optional and overrides each provider's default.
# MAX_MONTHLY_LLM_TOKENS is a project-wide soft cap on the analyze
# endpoint (input + output, summed across providers). Default 10M.

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
