# Root-level env example for docker-compose
# Copy to .env and adjust as needed

# Postgres
POSTGRES_USER=finrlx
POSTGRES_PASSWORD=finrlx
POSTGRES_DB=finrlx

# Backend
DATABASE_URL=postgresql+asyncpg://finrlx:finrlx@localhost:5432/finrlx
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
