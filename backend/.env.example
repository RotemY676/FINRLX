# Local dev: defaults to SQLite if DATABASE_URL is not set
# DATABASE_URL=sqlite+aiosqlite:///./finrlx_dev.db

# PostgreSQL (use for Docker Compose or production):
# DATABASE_URL=postgresql+asyncpg://finrlx:finrlx@localhost:5432/finrlx

DATABASE_ECHO=false
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]

# Phase 16 — Research fundamentals + peers provider.
# Leave empty (or unset) to keep the stub provider, which is the
# default and renders the "configure provider" empty state in the
# frontend without breaking anything.
# To activate real fundamentals + sector peers via Finnhub:
#   1. Sign up at https://finnhub.io/ (free tier, 60 calls/min).
#   2. Copy the API key from finnhub.io/dashboard.
#   3. Set both vars below.
# FUNDAMENTALS_PROVIDER=finnhub
# FINNHUB_API_KEY=your-key-here
